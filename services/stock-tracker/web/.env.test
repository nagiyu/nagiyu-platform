# Node Environment
NODE_ENV=test

# Application Configuration
APP_VERSION=0.0.0

# AWS Configuration
# Note: インメモリモード時は DynamoDB に接続しないが、変数自体の定義は必要。
# 実 dev/本番テーブル名は絶対に書かない（USE_IN_MEMORY_DB を外した際に dev DB を
# 汚染する事故を防ぐため、E2E 用のダミー名のみを置く）。
AWS_REGION=us-east-1
DYNAMODB_TABLE_NAME=stock-tracker-e2e-test

# NextAuth Configuration
AUTH_SECRET=test-secret-key-for-e2e-tests-must-be-at-least-32-characters-long

# Authentication skip for E2E tests
# E2E テストでは Auth サービスを使わずにテストユーザーでログイン
SKIP_AUTH_CHECK=true
TEST_USER_EMAIL=test-admin@example.com
TEST_USER_ROLES=stock-admin

# Repository type for E2E tests
# インメモリリポジトリを使用することで DynamoDB への接続を回避
USE_IN_MEMORY_DB=true

# Web Push (VAPID) - テスト用ダミー値
# E2E テストでは使用されないが、環境変数が未定義だとエラーになるため設定
VAPID_PUBLIC_KEY=test-dummy-vapid-public-key-not-used-in-e2e-tests
VAPID_PRIVATE_KEY=test-dummy-vapid-private-key-not-used-in-e2e-tests
