                <mxCell id="q1" value="L2 コンストラクトに&#xa;grantXxx メソッドがあるか？&#xa;（grantRead / grantInvoke 等）" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="320" y="200" width="320" height="100" as="geometry"/>
