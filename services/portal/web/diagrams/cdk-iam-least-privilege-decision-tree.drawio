<mxfile host="app.diagrams.net" modified="2026-06-13T00:00:00.000Z" agent="draw.io" version="21.0.0">
  <diagram name="権限付与手段の選択フロー" id="decision-tree">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- タイトル -->
        <mxCell id="title" value="CDK IAM 権限付与手段の選択フロー" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="800" height="40" as="geometry" />
        </mxCell>

        <!-- スタートノード -->
        <mxCell id="start" value="権限を付与したい" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="80" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- 判断1: L2 コンストラクトに grantXxx があるか -->
        <mxCell id="q1" value="L2 コンストラクトに&#xa;grantXxx メソッドがあるか？&#xa;（grantRead / grantInvoke 等）" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="200" width="320" height="100" as="geometry" />
        </mxCell>

        <!-- スタート → 判断1 -->
        <mxCell id="edge-start-q1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="start" target="q1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Grant メソッドを使う（YES）-->
        <mxCell id="use-grant" value="Grant メソッドを使う&#xa;（例: table.grantReadWriteData(fn)）&#xa;&#xa;・ARN を自分で書かなくてよい&#xa;・必要なアクションが自動設定される" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="650" y="210" width="270" height="100" as="geometry" />
        </mxCell>

        <!-- 判断1 → Grant（YES） -->
        <mxCell id="edge-q1-grant" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="q1" target="use-grant" parent="1">
          <mxGeometry relative="1" as="geometry" />
          <mxCell style="text;align=left;" value="YES" as="label" />
        </mxCell>

        <!-- 判断2: プレフィクス絞り・Condition が必要か -->
        <mxCell id="q2" value="プレフィクス絞り・Condition など&#xa;細かい制限が必要か？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="380" width="320" height="90" as="geometry" />
        </mxCell>

        <!-- 判断1 → 判断2（NO） -->
        <mxCell id="edge-q1-q2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="q1" target="q2" parent="1">
          <mxGeometry relative="1" as="geometry" />
          <mxCell style="text;align=left;" value="NO" as="label" />
        </mxCell>

        <!-- addToRolePolicy を使う（YES） -->
        <mxCell id="use-add-policy" value="addToRolePolicy で&#xa;PolicyStatement を書く&#xa;&#xa;・プレフィクス単位で絞れる&#xa;・Condition（条件）を付けられる" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="650" y="385" width="270" height="100" as="geometry" />
        </mxCell>

        <!-- 判断2 → addToRolePolicy（YES） -->
        <mxCell id="edge-q2-add" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="q2" target="use-add-policy" parent="1">
          <mxGeometry relative="1" as="geometry" />
          <mxCell style="text;align=left;" value="YES" as="label" />
        </mxCell>

        <!-- 判断3: クロスアカウント・Grant がない操作か -->
        <mxCell id="q3" value="クロスアカウント、CDK 管理外&#xa;リソース、または Grant が&#xa;存在しない操作か？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="560" width="360" height="100" as="geometry" />
        </mxCell>

        <!-- 判断2 → 判断3（NO） -->
        <mxCell id="edge-q2-q3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="q2" target="q3" parent="1">
          <mxGeometry relative="1" as="geometry" />
          <mxCell style="text;align=left;" value="NO" as="label" />
        </mxCell>

        <!-- PolicyStatement 直接構築（YES） -->
        <mxCell id="use-policy-stmt" value="PolicyStatement を直接構築&#xa;（Arn.format で ARN を組み立てる）&#xa;&#xa;・ハードコードせず Stack.of(this)&#xa;  からアカウント/リージョンを引く" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="650" y="565" width="270" height="110" as="geometry" />
        </mxCell>

        <!-- 判断3 → PolicyStatement（YES） -->
        <mxCell id="edge-q3-stmt" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="q3" target="use-policy-stmt" parent="1">
          <mxGeometry relative="1" as="geometry" />
          <mxCell style="text;align=left;" value="YES" as="label" />
        </mxCell>

        <!-- 注意書き（NO ルート） -->
        <mxCell id="recheck" value="※ Grant メソッドを再確認する&#xa;（Secret.grantRead 等、見落としがある場合も）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="50" y="580" width="270" height="80" as="geometry" />
        </mxCell>

        <!-- 判断3 → 再確認（NO） -->
        <mxCell id="edge-q3-recheck" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="q3" target="recheck" parent="1">
          <mxGeometry relative="1" as="geometry" />
          <mxCell style="text;align=left;" value="NO" as="label" />
        </mxCell>

        <!-- 共通注意: * を使う場合は必ずコメントを残す -->
        <mxCell id="note-star" value="補足: Resource を * にせざるを得ない場合&#xa;（例: ecr:GetAuthorizationToken）は&#xa;「なぜ * なのか」コメントを残して&#xa;別ステートメントに切り出す" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="730" width="350" height="100" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
