                </mxCell>
                <mxCell id="q2" value="プレフィクス絞り・Condition など&#xa;細かい制限が必要か？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" parent="1" vertex="1">
