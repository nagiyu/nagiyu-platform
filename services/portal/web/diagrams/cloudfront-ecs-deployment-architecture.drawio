        </mxCell>

        <!-- ECS Fargate タスク -->
        <mxCell id="ecs-task" value="ECS Fargate タスク&#xa;nagiyu-root-task-prod&#xa;cpu: 256 / memory: 512&#xa;Container: portal-app&#xa;PORT: 3000&#xa;Public Subnet + assignPublicIp" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
