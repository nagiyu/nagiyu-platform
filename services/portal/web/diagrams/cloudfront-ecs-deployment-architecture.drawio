        <mxCell id="title" value="nagiyu-platform Portal 本番構成（CloudFront + ECS Fargate）" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=15;fontStyle=1;" vertex="1" parent="1">
