          <mxGeometry x="180" y="120" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- CloudFront -->
        <mxCell id="cf" value="CloudFront Distribution&#xa;nagiyu.com / dev.nagiyu.com&#xa;PRICE_CLASS_100&#xa;HTTP2_AND_3&#xa;CachingDisabled (デフォルト)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="370" y="190" width="240" height="100" as="geometry" />
        </mxCell>

