{
  "extends": "../../../configs/tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "playwright.config.ts", "tests/**/*"],
  "references": [
    { "path": "../../../libs/common" },
    { "path": "../../../libs/browser" },
    { "path": "../../../libs/ui" },
    { "path": "../core" }
  ]
}
