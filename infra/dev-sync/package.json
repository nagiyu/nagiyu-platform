{
  "name": "@nagiyu/infra-dev-sync",
  "version": "1.0.0",
  "description": "dev-sync Service AWS CDK Infrastructure",
  "main": "lib/dev-sync-stack.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "cdk": "npx cdk",
    "synth": "npx cdk synth",
    "deploy": "npx cdk deploy",
    "deploy:dev": "npx cdk deploy --context env=dev --all",
    "deploy:prod": "npx cdk deploy --context env=prod --all",
    "diff": "npx cdk diff",
    "diff:dev": "npx cdk diff --context env=dev",
    "diff:prod": "npx cdk diff --context env=prod"
  },
  "dependencies": {
    "@nagiyu/infra-common": "*",
    "aws-cdk-lib": "^2.258.0",
    "constructs": "^10.6.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.11"
  }
}
