{
  "name": "@nagiyu/infra-quick-clip",
  "version": "0.1.0",
  "description": "QuickClip AWS CDK Infrastructure",
  "main": "lib/quick-clip-stack.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "echo \"No tests configured\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cdk": "npx cdk",
    "synth": "npx cdk synth",
    "deploy": "npx cdk deploy",
    "deploy:dev": "npx cdk deploy --context env=dev",
    "deploy:prod": "npx cdk deploy --context env=prod",
    "diff": "npx cdk diff"
  },
  "dependencies": {
    "@nagiyu/infra-common": "*",
    "aws-cdk-lib": "^2.243.0",
    "constructs": "^10.4.4",
    "source-map-support": "^0.5.21"
  }
}
